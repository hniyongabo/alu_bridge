rules_version = '2';

// INTERIM rules: require sign-in for all access, matching firestore.rules.
// To be tightened alongside the Firestore rules before final submission
// (e.g. resumes/{studentUid}/... should only be writable by that student).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
